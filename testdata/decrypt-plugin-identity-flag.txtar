stdin input.json
exec tofu-age-encryption --encrypt --recipient age1test1qypqxpqhuqytu

stdin stdout
exec tail -n +2
cp stdout cipher.json

stdin cipher.json
exec tofu-age-encryption --decrypt --identity AGE-PLUGIN-TEST-1QYPQXPQWSMN6R
cmp stdout stdout.json

-- input.json --
{"payload":"c2VjcmV0"}

-- stdout.json --
{"magic":"OpenTofu-External-Encryption-Method","version":1}
{"payload":"c2VjcmV0"}
