stdin input.json
exec tofu-age-encryption --encrypt --recipient age1test1qypqxpqhuqytu --recipient age1s2r63x2q98nmv8ppjv5c2zv5xlm4lp0makhmtsumglwhhwnt2e5srs47qt

stdin stdout
exec tail -n +2
cp stdout cipher.json

stdin cipher.json
exec tofu-age-encryption --decrypt --identity-file plugin-identity.txt
cmp stdout stdout.json

stdin cipher.json
exec tofu-age-encryption --decrypt --identity-file x25519-key.txt
cmp stdout stdout.json

-- input.json --
{"payload":"c2VjcmV0"}

-- plugin-identity.txt --
