stdin input.json
exec tofu-age-encryption --encrypt --recipients-file recipients.txt

stdin stdout
exec sed 's/\("payload":"\)[^"]*/\1MASK/'
cmp stdout stdout.json

-- input.json --
{"payload":"c2VjcmV0"}

-- recipients.txt --
age1test1qypqxpqhuqytu

-- stdout.json --
{"magic":"OpenTofu-External-Encryption-Method","version":1}
{"payload":"MASK"}
