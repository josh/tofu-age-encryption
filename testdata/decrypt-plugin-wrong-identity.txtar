stdin input.json
exec tofu-age-encryption --encrypt --recipient age1test1qypqxpqhuqytu

stdin stdout
exec tail -n +2
cp stdout cipher.json

stdin cipher.json
! exec tofu-age-encryption --decrypt --identity-file wrong-identity.txt
cmp stdout stdout.json

-- input.json --
{"payload":"c2VjcmV0"}

-- wrong-identity.txt --
AGE-PLUGIN-TEST-1Q5RQWZQ3NWAV2

-- stdout.json --
{"magic":"OpenTofu-External-Encryption-Method","version":1}
